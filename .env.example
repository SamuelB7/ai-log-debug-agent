POSTGRES_USER=debug_agent
POSTGRES_PASSWORD=debug_agent
POSTGRES_DB=debug_agent
POSTGRES_PORT=5432
DATABASE_URL=postgresql://debug_agent:debug_agent@postgres:5432/debug_agent?schema=public
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password
ADMIN_NAME=DebugOps Admin
JWT_SECRET=change-me-super-secret
JWT_EXPIRES_IN=3600s

REDIS_URL=redis://redis:6379
LOG_QUEUE_NAME=logs
LOG_INGESTOR_API_KEYS=local-dev-key
LOG_INGESTOR_RATE_LIMIT_WINDOW_SECONDS=60
LOG_INGESTOR_RATE_LIMIT_MAX=600
LOG_WORKER_CONCURRENCY=5

OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX=logs
OPENSEARCH_INITIAL_ADMIN_PASSWORD=debug-agent-Admin123!

QDRANT_URL=http://qdrant:6333
DOCS_RAG_COLLECTION=docs_rag
DOCS_RAG_EMBEDDING_MODEL=text-embedding-3-small
DOCS_RAG_EMBEDDING_DIMENSIONS=1536

AI_AGENT_URL=http://ai-agent-service:8000
DOCS_RAG_URL=http://docs-rag-service:8001
OPENAI_API_KEY=replace-me
AI_AGENT_MODEL=gpt-4o-mini
AI_AGENT_HISTORY_LIMIT=8
AI_AGENT_REQUEST_TIMEOUT_SECONDS=10

GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
